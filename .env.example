# OpenAI (for AI features) — AI gracefully disables if absent
OPENAI_API_KEY=sk-xxx

# Stripe (for Pro subscription) — checkout & webhook fail-closed if absent
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Admin panel auth (HMAC-signed cookie). REQUIRED for admin login to work.
# ADMIN_SECRET: long random string used to sign the admin session cookie.
# ADMIN_PASSWORD_HASH: SHA-256 hex of the admin password (optional; falls back
#   to the built-in default hash if unset).
ADMIN_SECRET=change-me-to-a-long-random-string
ADMIN_PASSWORD_HASH=

# Cron job auth
CRON_SECRET=your-random-secret-here

# Site URL
NEXT_PUBLIC_SITE_URL=https://cryptoflowcheck.com
